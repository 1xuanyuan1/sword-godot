; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Sword Godot Study Port"
config/description="A non-official GPL-3.0 study port inspired by SDLPal"
config/icon="res://assets/ui/app_icon.png"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7")

[display]

window/size/viewport_width=320
window/size/viewport_height=200
window/size/window_width_override=960
window/size/window_height_override=600
window/stretch/mode="canvas_items"
window/handheld/orientation=0

[input_devices]

pointing/emulate_mouse_from_touch=false

[rendering]

environment/defaults/default_clear_color=Color(0, 0, 0, 1)
textures/canvas_textures/default_texture_filter=0
textures/vram_compression/import_etc2_astc=true
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
