## 返回从 0 开始的场景索引对应地点名；未知索引统一显示“未知地点”。
static func name_for_scene_index(scene_index: int) -> String:
	return SCENE_NAMES[scene_index] if scene_index >= 0 and scene_index < SCENE_NAMES.size() else "未知地点"


## 返回用于场景切换 Toast 的大区域名称，例如“仙灵岛·岸”归并为“仙灵岛”。
## 无效索引和未命名场景返回空字符串，调用方不应显示提示。
static func area_name_for_scene_index(scene_index: int) -> String:
	if scene_index < 0 or scene_index >= SCENE_NAMES.size():
		return ""
	var full_name: String = SCENE_NAMES[scene_index]
	if full_name.is_empty() or full_name == "未命名场景":
		return ""
	var area_name := full_name.get_slice("·", 0).strip_edges()
	var note_start := area_name.find("（")
	if note_start >= 0:
		area_name = area_name.left(note_start).strip_edges()
	return area_name


## 比较两个场景的大区域；仅跨区域时返回目标名称，同区域或初次载入返回空字符串。
static func toast_name_for_transition(previous_scene_index: int, scene_index: int) -> String:
	if previous_scene_index < 0:
		return ""
	var previous_area := area_name_for_scene_index(previous_scene_index)
	var next_area := area_name_for_scene_index(scene_index)
	return next_area if not next_area.is_empty() and next_area != previous_area else ""
